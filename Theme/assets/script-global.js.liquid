window.TYT = window.TYT || {};
window.proInCartJS = window.proInCartJS || {};
window.cartJS = window.cartJS    || {};
function ShopMoney(price) {return Haravan.formatMoney(price, "{{ shop.money_format }}");}
TYT.Helper = { 
	fetchData: function(url, target, callback) {
		fetch(url)
			.then(function(res) { return res.text(); })
			.then(function(html) {
				target.innerHTML = html;
				if (typeof callback === 'function') callback();
			})
			.catch(function(err) { console.warn('TYT.Helper.fetchData:', err); });
	},
	handleDefaultFormSubmit: function(selector) {
		var el = document.querySelector(selector);
		var form = el && el.querySelector('form');
		if (!form) return;
		form.addEventListener('submit', function(e) {
			e.preventDefault();
			var f = this;
			fetch(f.getAttribute('action'), {
				method: 'POST',
				headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
				body: new URLSearchParams(new FormData(f)).toString()
			}).then(function() {
				if (TYT.Toast) TYT.Toast.success();
				f.reset();
			});
		});
	},
	handleCustomizeFormSubmit: function(selector, formData) {
		var form = document.querySelector(selector);
		if (!form) return;
		form.addEventListener('submit', function(e) {
			e.preventDefault();
			var f = this;
			var val = function(sel) { var el = f.querySelector(sel); return el ? el.value : ''; };
			grecaptcha.ready(function() {
				grecaptcha.execute(window.TYT.recaptcha, { action: 'submit' })
					.then(function(token) {
						var tokenEl = f.querySelector('input[name="g-recaptcha-response"]');
						if (tokenEl) tokenEl.value = token;
						var payload = {
							form_type: 'contact',
							__RequestVerificationToken: val('input[name="__RequestVerificationToken"]'),
							utf8: '✓',
							'g-recaptcha-response': token
						};
						Object.keys(formData).forEach(function(key) {
							payload[key] = val(formData[key]);
						});

						fetch('/contact', {
							method: 'POST',
							headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
							body: new URLSearchParams(payload).toString()
						}).then(function() {
							alert('Cảm ơn bạn đã đăng ký thông tin. Chúng tôi sẽ sớm liên hệ với bạn!');
						});
					});
			});
		});
	},
	/** Debounce: chỉ gọi fn sau khi ngừng gọi được `wait` ms */
	delayTime: function(fn, wait) {
		return function() {
			var ctx = this, args = arguments;
			clearTimeout(fn._delayTimer);
			fn._delayTimer = setTimeout(function() { fn.apply(ctx, args); }, wait);
		};
	},
	/** Throttle: gọi fn tối đa 1 lần mỗi `wait` ms */
	throttle: function(fn, wait) {
		var last = 0, timer = null;
		return function() {
			var ctx = this, args = arguments;
			var now = Date.now();
			var remaining = wait - (now - last);
			if (remaining <= 0) {
				if (timer) { clearTimeout(timer); timer = null; }
				last = now;
				fn.apply(ctx, args);
			} else if (!timer) {
				timer = setTimeout(function() {
					last = Date.now(); timer = null;
					fn.apply(ctx, args);
				}, remaining);
			}
		};
	},
	/** Pad số thành 2 chữ số: 5 → "05" */
	padTime: function(n) { return n > 9 ? String(n) : '0' + n; },
	buyNowProdItem: function(id,quantity,action, callback) {
		var quantity = quantity || 1;
		var hasPromoApp = window.TYT && TYT.App && TYT.App.promotion !== 'none';
		function onSuccess(line_item) {
			if (typeof callback === 'function') {
				callback(null, line_item);
				return;
			}
			action = action || '/checkout';
			if (action === 'cart' || template === 'cart') {
				var el = document.querySelector('.layout-cart');
				if (el) {
					var x = el.getBoundingClientRect().top + window.scrollY;
					smoothScroll(x - 100, 500);
				}
				setTimeout(function() { window.location.reload(); }, 300);
				return;
			}
			if (action === 'modal') {
				HRT.All.getCartModal();
				return;
			}
			fetch(TYT.routes.cart)
				.then(function(res) { return res.json(); })
				.then(function(cart) {
					var overMin = typeof priceMin === 'undefined'
						|| priceMin === ''
						|| priceMin < (cart.total_price / 100);

					if (overMin) {
						window.location = '/checkout';
					} else {
						HRT.All.getCartModal();
					}
				});
		}
		function doAdd() {
			fetch(TYT.routes.cartAdd, {
				method: 'POST',
				headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
				body: 'quantity=' + quantity + '&id=' + id
			})
			.then(function(res) {
				if (!res.ok) return res.json().then(function(err) { throw err; });
				return res.json();
			})
			.then(function(line_item) { onSuccess(line_item); })
			.catch(function(err) {
				if (typeof callback === 'function') callback(err, null);
				else Haravan.onError(err);
			});
		}
		if (hasPromoApp && typeof buyXgetY !== 'undefined') {
			var currentId = id;
			buyXgetY.addCartBuyXGetY_detail(false, id, currentId, quantity, function() {
				if (typeof callback === 'function') {
					callback(null, null);
					return;
				}
				if (action === 'modal' || action === 'cart') {
					onSuccess(null);
				} else {
					window.location = '/checkout';
				}
			});
			return;
		}

		doAdd();
	},
	CountDown: (wrapper) => {
		var root = typeof wrapper === 'string'
			? document.querySelector(wrapper)
			: wrapper;
		var box = root && root.querySelector('.box-countdown');
		if (!box) return;

		var pad = TYT.Helper.padTime;
		var end = new Date(box.getAttribute('data-time')).getTime();
		var els = {
			days:    box.querySelector('.days'),
			hours:   box.querySelector('.hours'),
			minutes: box.querySelector('.minutes'),
			seconds: box.querySelector('.seconds')
		};

		var timer = setInterval(function() {
			var d = end - Date.now();
			if (d < 0) {
				Object.keys(els).forEach(function(k) { if (els[k]) els[k].textContent = '00'; });
				clearInterval(timer);
				return;
			}
			if (els.days)    els.days.textContent    = pad(Math.floor(d / 86400000));
			if (els.hours)   els.hours.textContent   = pad(Math.floor((d % 86400000) / 3600000));
			if (els.minutes) els.minutes.textContent = pad(Math.floor((d % 3600000)  / 60000));
			if (els.seconds) els.seconds.textContent = pad(Math.floor((d % 60000)    / 1000));
		}, 1000);
	},
};

/* ─────────────────────────────────────────
   COMPONENT — các UI component
───────────────────────────────────────── */
TYT.Component = {

	Modal: {
		_cls: { open: 'newModal-open', scroll: 'body-blockscrolled' },

		open: function(modalSelector, opts) {
			opts = opts || {};
			var cls = opts.scrollClass || this._cls.scroll;
			[document.body, document.documentElement].forEach(function(el) {
				el.classList.add('newModal-open', cls);
			});
			var modal = document.querySelector(modalSelector);
			if (modal && window.bootstrap) new bootstrap.Modal(modal).show();
		},

		close: function(scrollClass) {
			var cls = scrollClass || this._cls.scroll;
			[document.body, document.documentElement].forEach(function(el) {
				el.classList.remove('newModal-open', cls);
			});
		},

		/** Gắn trigger mở modal theo event delegation */
		bindOpen: function(triggerSelector, modalSelector, opts) {
			var self = this;
			document.body.addEventListener('click', function(e) {
				if (!e.target.closest(triggerSelector)) return;
				e.preventDefault();
				if (opts && opts.beforeOpen && opts.beforeOpen(e, modalSelector) === false) return;
				self.open(modalSelector, opts);
			});
		},

		/** Dọn class khi modal đóng (Bootstrap event) */
		onHidden: function(modalSelector, scrollClass) {
			var self = this;
			var modal = document.querySelector(modalSelector);
			if (modal) modal.addEventListener('hidden.bs.modal', function() {
				self.close(scrollClass);
			});
		}
	},

	Swiper: {
		_hook: '.js-swiper-slider:not(.swiper-initialized):not(.swiperCustomize)',
		init: function() {
			var nodes = document.querySelectorAll(this._hook);
			if (!nodes.length) return;
			nodes.forEach(function(el) {
				var ds  = el.dataset;
				var par = el.parentNode;
				new Swiper(el, {
					speed: 1500,
					loop: ds.loop !== undefined ? ds.loop !== 'false' : true,
					slidesPerView: ds.items,
					spaceBetween: parseInt(ds.margin) || 0,
					autoplay: ds.autoplay === 'true'
						? { delay: parseInt(ds.speed) || 3000, disableOnInteraction: false }
						: false,
					pagination: ds.dots === 'true' && par.querySelector('.swiper-pagination')
						? { el: par.querySelector('.swiper-pagination'), clickable: true }
						: false,
					navigation: (function() {
						var next = par.querySelector('.swiper-button-next');
						var prev = par.querySelector('.swiper-button-prev');
						return ds.nav === 'true' && next && prev
							? { nextEl: next, prevEl: prev } : false;
					}()),
					breakpoints: {
						0:   { slidesPerView: ds.xs || ds.items, spaceBetween: parseInt(ds.xsMargin  || ds.margin) || 0 },
						768: { slidesPerView: ds.sm || ds.items, spaceBetween: parseInt(ds.smMargin  || ds.margin) || 0 },
						992: { slidesPerView: ds.md || ds.items, spaceBetween: parseInt(ds.mdMargin  || ds.margin) || 0 }
					}
				});
			});
		}
	},

	Quantity: {
		init: function() {
			document.body.addEventListener('click', function(e) {
				var btn = e.target.closest('.js-quantity');
				if (!btn) return;
				e.preventDefault();
				var action  = btn.getAttribute('quantity-action');
				var input   = btn.parentNode.querySelector('input');
				var current = parseInt(input && input.value, 10);
				if (!action || isNaN(current)) return;
				if (action === 'minus' && current > 1) input.value = current - 1;
				if (action === 'plus')                 input.value = current + 1;
			});
		}
	},
	
	expandDescription: {
		moreTxt: 'Xem thêm',
		lessTxt: 'Rút gọn',
		init: function() {
			var _this = this;
			document.querySelectorAll('expand-description').forEach(function(comp) {
				var maxH  = parseInt(comp.dataset.maxHeight) || 220;
				var body  = comp.querySelector('.js-ed-body');
				var btn   = comp.querySelector('.js-ed-btn');
				var label = comp.querySelector('.js-ed-btn-text');

				if (body.scrollHeight <= maxH) {
					body.style.height = 'auto';
					btn.style.display = 'none';
					return;
				}

				body.style.height = maxH + 'px';

				btn.addEventListener('click', function() {
					var isOpen = comp.classList.contains('is-open');
					body.style.height = (isOpen ? maxH : body.scrollHeight) + 'px';
					comp.classList.toggle('is-open', !isOpen);
					label.textContent = isOpen ? _this.moreTxt : _this.lessTxt;
				});
			});
		}
	},
	init: function() {
		this.Swiper.init();
		this.Quantity.init();
		
	}
};
TYT.Modal = TYT.Component.Modal;
document.addEventListener('DOMContentLoaded', function() {
	TYT.Component.init();
});