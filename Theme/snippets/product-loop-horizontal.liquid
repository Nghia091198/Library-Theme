{% assign on_sale = false %}
{% if product.available and product.variants.first.compare_at_price > product.variants.first.price %}
{% assign on_sale = true %}
{% endif %}

{% comment %}Tính giá khuyến mãi{% endcomment %}
{% assign price_sale = 0 %}
{% if product.variants.first.compare_at_price > product.variants.first.price %}
{% assign price_sale = product.variants.first.compare_at_price | minus: product.variants.first.price | divided_by:product.variants.first.compare_at_price | times : 100 | round : 0 %}
{% endif %}

{% assign sold_out = true %}
{% if product.available  %}
{% assign sold_out = false %}
{% endif %}  

{%- assign label1 = '' -%}
{%- assign label2 = '' -%}
{%- for tag in product.tag -%}
{%- if tag contains 'label1_' -%}{%- assign label1 = tag | split: 'label1_' | last -%}{%- endif -%}
{%- if tag contains 'label2_' -%}{%- assign label2 = tag | split: 'label2_' | last -%}{%- endif -%}
{%- endfor -%}
<div class="product-loop product-horizontal" data-id="{{ product.variants.first.id }}">
	<div class="product-inner">
		<div class="proloop--image">
			<a href="{{ product.url }}" class="ratio-image" title="{{ product.title | strip }}" aria-label="{{ product.title | strip }}">
				<img fetchpriority="low" class="lazyload" loading="lazy" decoding="async" src="{%if product.images.size > 0%}{{ product.featured_image | product_img_url: 'master' }}{%else%}{{'no_image.jpg' | asset_url}}{%endif%}" width="300" height="300" alt="{{product.title}}">
			</a>
		</div>
		<div class="proloop--detail">
			{%- if isTag and label1 != '' or label2 != '' or sold_out -%}
			<div class="list-tags">
				{%- if label1 != '' -%}<span class="tag-item" style="--proloop-label-bg: {{settings.label1_bg_color}};--proloop-label-text: {{settings.label1_text_color}};">{{label1}}</span>{%- endif -%}
				{%- if label2 != '' -%}<span class="tag-item" style="--proloop-label-bg: {{settings.label2_bg_color}};--proloop-label-text: {{settings.label2_text_color}};">{{label2}}</span>{%- endif -%}
				{%- if sold_out != '' -%}<span class="tag-item soldout">{{settings.product_soldout}}</span>{%- endif -%}
			</div>
			{%- endif -%}
			<div class="title">
				<a href="{{product.url}}" title="{{product.title}}">{{product.title}}</a>
			</div>
			<div class="block-proloop-price {%if price_sale > 0%}highlight{%endif%}">
				<div class="pro--price">
					{%- if product.variants[0].price > 0 -%}
					{{product.variants[0].price | money}}
					{%- else -%}
					<a href="{{settings.product_contact_url}}" rel="nofollow" title="{{settings.product_contact_title}}">{{settings.product_contact_title}}</a>
					{%- endif -%}
				</div>
				{%- if on_sale -%}
				<div class="pro--price-original"><del>{{product.variants[0].compare_at_price | money}}</del></div>
				<div class="pro--price-percent">-{{price_sale}}%</div>
				{%- endif -%}
			</div>
			{%- if quickview -%}
			<div class="block-addcart">
				<button type="button" class="js-loop-quickview btn-quickview button" data-handle="{{ product.handle }}" aria-label="Xem nhanh {{ product.title | strip }}">
					<svg class="no-translate icon-svg"><use xlink:href="#ic-cart-plus"></use></svg> Xem nhanh
				</button>
			</div>
			{%- endif -%}
		</div>
	</div>
</div>
