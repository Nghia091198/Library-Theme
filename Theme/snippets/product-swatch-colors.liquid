<style>
{%- for i in (1..30) -%}
{%- capture show_color -%}use_color_filter_{{ i }}{%- endcapture -%}
{%- capture name_color -%}color_name_new_{{ i }}{%- endcapture -%}
{%- capture code_color -%}color_code_new_{{ i }}{%- endcapture -%}
{%- assign set_name_color = settings[name_color] | downcase | handleize -%}
{%- if settings[show_color] -%}
.swatch .swatch-element.swatch-color label:not(.swatch-label__image).{{ set_name_color }} {
	background: {{ settings[code_color] }};
}
{%- endif -%}
{%- endfor -%}
</style>
