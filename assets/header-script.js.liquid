TYT.Header = TYT.Header || {};
TYT.Header = {
	_sel: {
		bodyHtml: 'body,html',
		topbar: '.topbar',
		header: 'header',
		menuToggle: '.js-open-menu-mobile',
		menuMobile: '#menu-mobile',
		menuWrapper: '#menu-mobile .menu-wrapper',
		submenu: 'submenu',
		menuDropdown: '.js-menu-dropdown'
	},
	_cls: {
		open: 'opened',
		menuOpen: 'menu-open',
		clicked: 'clicked',
		submenuOpen: 'submenu-open',
		blockScroll: 'body-blockscrolled',
		isFixed: 'is-fixed',
		isHidden: 'is-hidden'
	},
	init: function() {
		this.menuMobile();
		this.headerScroll();
	},
	menuMobile: function() {
		var SEL = this._sel, CLS = this._cls, self = this;
		TYT.Helper.fetchData('/?view=menu-mobile', $(SEL.menuWrapper));
		document.documentElement.style.setProperty('--viewport-height', window.innerHeight + 'px');
		var navBottom = document.querySelector('.navbar-bottom');
		if (navBottom) {
			document.documentElement.style.setProperty('--header-bottom-height', (navBottom.offsetHeight + 50) + 'px');
		}
		var headerHeight = $(SEL.header).outerHeight();
		setTimeout(function() {
			if ($(SEL.topbar).length) headerHeight = parseInt(headerHeight + $(SEL.topbar).outerHeight(), 10);
			$(SEL.menuMobile).css('top', headerHeight);
		}, 1000);
		$('body').on('click', SEL.menuToggle, function(e) {
			e.preventDefault();
			var $btn = $(this);
			if ($btn.hasClass(CLS.open)) {
				$(SEL.menuMobile).find(SEL.submenu).removeClass(CLS.submenuOpen);
				$(SEL.menuMobile).find(SEL.menuDropdown).removeClass(CLS.clicked);
				$(SEL.bodyHtml).addClass(CLS.blockScroll);
			}
			$btn.toggleClass(CLS.open);
			$(SEL.menuMobile).toggleClass(CLS.menuOpen);
			$(SEL.bodyHtml).toggleClass(CLS.blockScroll);
		});
		$('body').on('click', SEL.menuDropdown, function(e) {
			e.preventDefault();
			$(this).toggleClass(CLS.clicked);
			$(this).parent().next().toggleClass(CLS.submenuOpen);
		});
	},
	headerScroll: function() {
		var SEL = this._sel, CLS = this._cls;
		var lastScroll = 0;
		var header = document.querySelector(SEL.header);
		var topbar = document.querySelector(SEL.topbar);
		if (!header) return;
		var getHeaderHeight = function() {
			var h = header.offsetHeight;
			if (topbar) h += topbar.offsetHeight;
			return h;
		};
		var onScroll = function() {
			var currentScroll = window.pageYOffset || document.documentElement.scrollTop;
			var headerHeight = getHeaderHeight();
			if (currentScroll > headerHeight) {
				header.classList.add(CLS.isFixed);
				if (currentScroll > lastScroll) {
					header.classList.add(CLS.isHidden);
					$(SEL.menuMobile).css('top', header.offsetHeight);
					document.documentElement.style.setProperty('--viewport-height', (window.innerHeight + 80) + 'px');
				} else {
					header.classList.remove(CLS.isHidden);
					$(SEL.menuMobile).css('top', getHeaderHeight());
					document.documentElement.style.setProperty('--viewport-height', window.innerHeight + 'px');
				}
			} else {
				header.classList.remove(CLS.isFixed, CLS.isHidden);
			}
			lastScroll = currentScroll;
		};
		window.addEventListener('scroll', onScroll);
	}
};
document.addEventListener('DOMContentLoaded', function() {
	TYT.Header.init();
});
