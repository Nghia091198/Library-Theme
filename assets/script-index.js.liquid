window.TYT.Index = {
	init: function(){
		var that = this;
		that.initCountDown();
		that.homeCollectionTab();
		that.homeLookBook();
		that.homeSubscribe();
		that.homeBrand();
	},
	initCountDown: () => {
		if($('.section-countdown .box-countdown').length > 0) {
			TYT.Helper.CountDown('.section-countdown');
		}
	},
	homeCollectionTab: () => {
		const listCollectionTab = ['.collection-tab-1'];
		listCollectionTab.forEach(function(tabElmt,index){
			const tabButton = $(tabElmt).find('.nav-item > a');
			tabButton.on("click",function(e){
				e.preventDefault();
				var fetchUrl = `/collections/all?view=home-collection-no-tab`;
				let handleCol = $(this).attr('data-handle'),
						elemtTab = $(this).attr('href'),titleTab = $(this).attr('data-title');
				if (handleCol != '' && handleCol !== '/collections/') {fetchUrl = `${handleCol}?view=home-product-tab`;}
				if (!$(elemtTab).hasClass('ajax-loaded')) {
					$(elemtTab).addClass('ajax-loaded');
					$.ajax({
						type: 'GET',
						url: fetchUrl,
						success: function(data){
							$(elemtTab).find('.js-html-tab').append(data);
						}
					})
				}
			})
		})
	},
	homeLookBook: () => {
		$('.popover-dot[data-toggle="popover"]').popover({
			html: true,
			animation: true,
			sanitize: false,
			placement: function ( popover, trigger ){
				var placement = jQuery( trigger ).attr( 'data-placement' );
				var dataClass = jQuery( trigger ).attr( 'data-class' );
				jQuery( trigger ).addClass( 'is-active' );
				jQuery( popover).addClass( dataClass );
				return placement;
			},
			content: function() {
				var elementId  = $(this).attr("data-content-id");
				return $(elementId).html();
			},
		});
		$("body").on("click", '.popover-dot[data-toggle="popover"]', function(e) {
			$('.popover-dot[data-toggle="popover"]').each(function () {			
				if (!$(this).is(e.target) && $(this).has(e.target).length === 0 && $('.popover').has(e.target).length === 0) {
					$(this).popover('hide');
				}
			});
		});
		$('.section-lookbook .popover-dot:eq(0)').trigger("click");
	},
	homeSubscribe: () => {
		if($('.section-subcribe').length > 0) {
			TYT.Helper.handleDefaultFormSubmit(".js-subcribe-form");
		}
	},
	homeBrand: () => {
		if($('.section-brand').length > 0) {
			const brandElemt = document.querySelector(".section-brand");
			var timer=null,$lights = $('.item-brand'),loopTimer = null,loopInterval = 1;
			function stop() {
				if (timer) clearInterval(timer);
        if (loopTimer) clearTimeout(loopTimer);
			}
			function start() {
				var current = 0;
				timer = setInterval(function() {
            if (current >= $lights.length) {
                stop();
                loopTimer = setTimeout(() => start(), loopInterval * 1000);
                return;
            }
            $lights.filter('.active').removeClass('active');
            $lights.eq(current).addClass('active');
            current++;
        }, loopInterval * 1000);
			}
			const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            start();
						//console.log("Starting");
          } else {
            stop();
						//console.log("Pausing");
          }
        });
      },
      {
        threshold: 0.2, // Trigger when 50% of the section is visible
      }
    );
    
    observer.observe(brandElemt);
		}
	}
}
window.addEventListener("load", function(){
	window.TYT.Index.init();
});
