{%- if href != blank -%}
{%- assign link_css_url = href -%}
{%- elsif css_file != blank -%}
{%- assign link_css_url = css_file | asset_url -%}
{%- endif -%}
{%- if link_css_url != blank -%}
{%- if blocking -%}
<link rel="stylesheet preload" href="{{ link_css_url }}" as="style">
{%- else -%}
<link rel="preload" href="{{ link_css_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'"><noscript><link rel="stylesheet" href="{{ link_css_url }}"></noscript>
{%- endif -%}
{%- endif -%}
