<script async defer>
	let mainSlider = () => {
		const el = document.querySelector('.js-main-slider');
		if (!el || el.classList.contains('swiper-initialized')) return;
		return new Swiper(el, {
			loop: true,
			spaceBetween: 10,
			effect: 'fade',
			autoplay: { delay: 4000, disableOnInteraction: false },
			navigation: {
				nextEl: '.main-slider .swiper-button-next',
				prevEl: '.main-slider .swiper-button-prev',
			},
			pagination: {
				el: '.main-slider .swiper-pagination',
				clickable: true,
			},
		});
	};
	let recapchaRender = () => {
		let input = $('input[name="g-recaptcha-response"]');
		input.each(function(index, elemt) {
			let $elemt = $(elemt);
			let $nextElem = $elemt.next();
			if ($nextElem.length && $nextElem.prop('tagName') === 'NOSCRIPT') {
				let apiSrcRecapcha = $nextElem.attr('src');
				if (!apiSrcRecapcha) return;
				let idInput = $elemt.attr('id');
				let _token = apiSrcRecapcha.split('render=')[1];
				let script = document.createElement('script');
				script.async = true;
				script.src = apiSrcRecapcha;
				document.body.appendChild(script);
				script.onload = function () {
					setTimeout(function () {
						grecaptcha.ready(function () {
							grecaptcha.execute(_token, { action: 'submit' }).then(function (token) {
								document.getElementById(idInput).value = token;
							});
						});
					}, 1000);
				};
			}
		});
	};
	let loadThirtyParty = () => {
		// Load tiktok, zalo, facebook, google, etc.
	};
	document.addEventListener('DOMContentLoaded', function() {
		if (window.main && window.main.template && window.main.template.includes('index')) {
			mainSlider();
		}
		setTimeout(function() {
			recapchaRender();
			loadThirtyParty();
		}, 3000);
		function loadStyles(stylesheetUrls) {
			stylesheetUrls.forEach(url => {
				const link = document.createElement('link');
				link.rel = 'preload';
				link.as = 'style';
				link.href = url;
				link.onload = function() {
					this.onload = null;
					this.rel = 'stylesheet';
				};
				document.head.appendChild(link);
			});
		}
		function loadScripts(scriptUrls) {
			var index = 0;
			function loadNext() {
				if (!scriptUrls || index >= scriptUrls.length) return;
				var script = document.createElement('script');
				script.src = scriptUrls[index];
				script.onload = function() {
					index += 1;
					loadNext();
				};
				script.onerror = function() {
					index += 1;
					loadNext();
				};
				document.head.appendChild(script);
			}
			loadNext();
		}
		if (window.main) {
			loadStyles(window.main.csscallafter);
			loadScripts(window.main.scriptcallafter);
		}
	});
</script>
