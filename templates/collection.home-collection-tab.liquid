{% layout none %}
{%-if collection.products.size > 0-%}
{%- for product in collection.products -%}
<div class="block-product col-lg-3 col-md-6 col-sm-6 col-6">
	{%- include 'product-loop' with section: sectionInd -%}
</div>
{%- endfor -%}
{%- else -%}
{% for i in (1..8) %}
{% include 'product-loop-no'%}
{% endfor%}
{%- endif -%}