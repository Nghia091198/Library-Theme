{%- layout none -%}
[{%-for article in search.results limit: 4 -%}
{
"title":"{{article.title | escape}}",
"url":"{{article.url}}",
"blog":"{{article.blog.title}}",
"blog_url":"{{article.blog.url}}",
"thumbnail": "{%if article.image %}{{ article.image.src | img_url: 'compact' }}{%else%}//hstatic.net/0/0/global/design/theme-default/no-image.png{%endif%}"
},
{%-endfor-%}
{"total_search":"{{ search.results.size}}"}
]